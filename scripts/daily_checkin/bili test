#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Bilibili 成长值功能测试版（只读，不签到、不投币、不分享）
用途：验证 Cookie 有效性 + 今日成长值明细 + 等级进度输出格式

用法（任选其一）：
  1. 环境变量:  set BILIBILI_COOKIE=xxx   (Windows)
                export BILIBILI_COOKIE=xxx (Linux/Mac)
                python bilibili_test.py
  2. 直接粘贴:  python bilibili_test.py 然后按提示粘贴 Cookie
"""

import os
import sys
import requests


def test(cookie: str):
    headers = {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
        'Cookie': cookie,
        'Referer': 'https://www.bilibili.com/'
    }

    # ── 1. 验证 Cookie & 读取等级信息 ──
    print("=" * 40)
    print("步骤 1/2: 验证 Cookie（nav 接口）")
    try:
        r = requests.get('https://api.bilibili.com/x/web-interface/nav',
                         headers=headers, timeout=10)
        d = r.json()
    except Exception as e:
        print(f"❌ 请求失败: {e}")
        return

    if d.get('code') != 0:
        print(f"❌ Cookie 失效或异常: code={d.get('code')} message={d.get('message')}")
        return

    data = d['data']
    info = data['level_info']
    level, cur_exp, next_exp = info['current_level'], info['current_exp'], info['next_exp']

    print(f"✅ Cookie 有效")
    print(f"用户: {data['uname']}")
    print(f"硬币余额: {data.get('money', '?')}")
    print(f"[调试] level_info 原始返回: {info}")

    # ── 2. 今日任务经验明细 ──
    print("=" * 40)
    print("步骤 2/2: 今日成长值明细（exp/reward 接口）")
    today_exp = None
    try:
        r = requests.get('https://api.bilibili.com/x/member/web/exp/reward',
                         headers=headers, timeout=10)

        print(f"[调试] 请求 URL: {r.url}")
        print(f"[调试] HTTP 状态: {r.status_code}, 前100字符: {r.text[:100]}")

        d = r.json()
        print(f"[调试] exp/reward 原始返回: {d}")
        if d.get('code') == 0:
            rw = d['data']
            login_exp = 5 if rw.get('login') else 0
            watch_exp = 5 if rw.get('watch') else 0
            share_exp = 5 if rw.get('share') else 0
            coin_exp = int(rw.get('coins', 0) or 0)
            today_exp = login_exp + watch_exp + share_exp + coin_exp
            print(f"  登录: +{login_exp}  观看: +{watch_exp}  分享: +{share_exp}  投币: +{coin_exp}")
        else:
            print(f"⚠️ 接口返回异常: code={d.get('code')} message={d.get('message')}")
    except Exception as e:
        print(f"⚠️ 请求失败: {e}")

    # ── 3. 模拟推送输出 ──
    print("=" * 40)
    print("最终推送效果预览：")
    print()
    print(f"📺 Bilibili [账号1]")
    print(f"用户: {data['uname']}")
    if today_exp is not None:
        print(f"📈 今日成长值: +{today_exp}")
    if isinstance(next_exp, int) and next_exp > 0:
        remain = next_exp - cur_exp
        days = (remain + 64) // 65
        print(f"🏅 当前等级: Lv{level}（{cur_exp}/{next_exp}）")
        print(f"⏫ 距离 Lv{level + 1} 还需: {remain} 成长值（约 {days} 天）")
    else:
        print(f"🏅 当前等级: Lv{level}（已满级）")


def main():
    cookie = os.environ.get('BILIBILI_COOKIE', '').strip()
    if not cookie:
        try:
            cookie = input("未检测到 BILIBILI_COOKIE 环境变量，请粘贴 Cookie 后回车:\n> ").strip()
        except EOFError:
            cookie = ''
    if not cookie:
        print("❌ 未提供 Cookie，退出")
        sys.exit(1)

    # 支持多账号（& 或换行分隔），逐个测试
    cookies = [c.strip() for c in cookie.replace('\n', '&').split('&') if c.strip()]
    for i, c in enumerate(cookies):
        if i > 0:
            print('\n' + '#' * 50 + '\n')
        test(c)


if __name__ == '__main__':
    main()
